<Window x:Class="JoystickInputTuner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JoystickInputTuner"
        Height="900"
        Width="1320"
        MinHeight="760"
        MinWidth="1100"
        Background="#1A1A1A"
        Foreground="#F3F3F3">
    <Window.Resources>
        <SolidColorBrush x:Key="BrushBg" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="BrushCard" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="BrushCardAlt" Color="#202020"/>
        <SolidColorBrush x:Key="BrushBorder" Color="#454545"/>
        <SolidColorBrush x:Key="BrushText" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="BrushHint" Color="#B8B8B8"/>
        <SolidColorBrush x:Key="BrushAccent" Color="#FF2D55"/>

        <Style x:Key="FineDeltaSliderStyle" TargetType="Slider">
            <Setter Property="SmallChange" Value="0.01"/>
            <Setter Property="LargeChange" Value="0.05"/>
            <Setter Property="TickPlacement" Value="None"/>
            <Setter Property="IsSnapToTickEnabled" Value="False"/>
        </Style>
        <Style x:Key="FineCenterDeltaSliderStyle" TargetType="Slider">
            <Setter Property="SmallChange" Value="0.005"/>
            <Setter Property="LargeChange" Value="0.02"/>
            <Setter Property="TickPlacement" Value="None"/>
            <Setter Property="IsSnapToTickEnabled" Value="False"/>
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#101010"/>
            <Setter Property="Background" Value="#F2F2F2"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#101010"/>
            <Setter Property="Background" Value="#F2F2F2"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#DADADA"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#CFCFCF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{StaticResource BrushText}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#404040"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#484848"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#525252"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Background="#202020">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock x:Name="AppTitleTextBlock" FontSize="24" FontWeight="SemiBold" Text="JoystickInputTuner"/>
                    <TextBlock x:Name="AppSubtitleTextBlock" Foreground="#A0A0A0" Margin="0,4,0,0"
                               Text="Yaw axis spike filter"/>
                    <TextBlock x:Name="AppVersionTextBlock" Foreground="#808080" Margin="0,2,0,0" FontSize="12"
                               Text="2.0.0"/>
                </StackPanel>

                <TextBlock x:Name="ProfilesHeaderTextBlock" Grid.Row="1" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"
                           Text="Profiles"/>

                <ListBox x:Name="ProfilesListBox" Grid.Row="2" Background="#252525" BorderBrush="#434343"
                         SelectionChanged="ProfilesListBox_OnSelectionChanged">
                    <ListBoxItem Content="Default" IsSelected="True"/>
                </ListBox>

                <UniformGrid Grid.Row="3" Columns="4" Margin="0,8,0,8">
                    <Button x:Name="AddProfileButton" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,6,0" Content="Add" Click="AddProfileButton_OnClick"/>
                    <Button x:Name="DeleteProfileButton" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Content="Delete" Click="DeleteProfileButton_OnClick"/>
                    <Button x:Name="LoadProfileButton" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Content="Load" Click="LoadProfileButton_OnClick"/>
                    <Button x:Name="SaveProfileButton" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0" Content="Save" Click="SaveProfileButton_OnClick"/>
                </UniformGrid>

                <Border Grid.Row="5" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="8" Padding="8" Background="#262626">
                    <StackPanel>
                        <TextBlock x:Name="InstructionHeaderTextBlock" FontWeight="SemiBold" Margin="0,0,0,6" Text="Instruction"/>
                        <TextBlock x:Name="InstructionTextBlock" TextWrapping="Wrap" Foreground="#B8B8B8"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Background="#202020">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="ProfileTitleTextBlock" FontSize="36" FontWeight="SemiBold" Text="Profile: &quot;Default&quot;"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="RefreshDevicesButton" Style="{StaticResource SecondaryButtonStyle}" Content="Refresh devices" Click="RefreshDevicesButton_OnClick"/>
                        <Button x:Name="ApplySettingsButton" Style="{StaticResource SecondaryButtonStyle}" Content="Apply" Click="ApplySettingsButton_OnClick"/>
                        <Button x:Name="StartButton" Style="{StaticResource PrimaryButtonStyle}" Width="100" Content="Start" Click="StartButton_OnClick"/>
                        <Button x:Name="StopButton" Style="{StaticResource SecondaryButtonStyle}" Width="100" Content="Stop" Click="StopButton_OnClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl x:Name="MainTabControl" Grid.Row="1" Background="#202020" BorderBrush="#3D3D3D">
                <TabItem x:Name="InputTab" Header="Input">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,6,8">
                                <StackPanel>
                                    <TextBlock x:Name="InputSourceHeaderTextBlock" FontSize="23" FontWeight="SemiBold" Margin="0,0,0,10" Text="Input Source"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="DeviceLabelTextBlock" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Device"/>
                                        <ComboBox x:Name="DeviceComboBox" Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,0,8"
                                                  DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                                                  SelectionChanged="DeviceComboBox_OnSelectionChanged"/>

                                        <TextBlock x:Name="AxisLabelTextBlock" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Axis"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                            <ComboBox x:Name="AxisComboBox" Width="220" Height="30"
                                                      DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                                                      SelectionChanged="AxisComboBox_OnSelectionChanged"/>
                                            <Button x:Name="DetectAxisButton" Style="{StaticResource SecondaryButtonStyle}" Content="Detect axis" Click="DetectAxisButton_OnClick"/>
                                        </StackPanel>

                                        <TextBlock x:Name="PollingLabelTextBlock" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Polling (Hz)"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                            <Slider x:Name="PollingSlider" Width="240" Minimum="20" Maximum="500" TickFrequency="10"
                                                    IsSnapToTickEnabled="True" ValueChanged="PollingSlider_OnValueChanged" Value="175"/>
                                            <TextBlock x:Name="PollingValueTextBlock" VerticalAlignment="Center" Margin="10,0,0,0" Width="60" Text="175"/>
                                        </StackPanel>

                                        <TextBlock x:Name="OutputSinkLabelTextBlock" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Output sink"/>
                                        <ComboBox x:Name="OutputSinkComboBox" Grid.Row="3" Grid.Column="1" Height="30" Margin="0,0,0,8"
                                                  SelectionChanged="OutputSinkComboBox_OnSelectionChanged"/>

                                        <TextBlock x:Name="ProfileLabelTextBlock" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Profile name"/>
                                        <TextBox x:Name="ProfileNameTextBox" Grid.Row="4" Grid.Column="1" Height="30" Margin="0,0,0,8"
                                                 TextChanged="ProfileNameTextBox_OnTextChanged" Text="Default"/>

                                        <TextBlock x:Name="MovementHintTextBlock" Grid.Row="5" Grid.ColumnSpan="2" Foreground="#A0A0A0" TextWrapping="Wrap"
                                                   Text="Tip: click Detect axis, then move the joystick axis you want to use."/>
                                    </Grid>

                                    <TextBlock x:Name="AxisBindLockHeaderTextBlock" FontSize="18" FontWeight="SemiBold" Margin="0,14,0,8"
                                               Text="Axis lock by button"/>
                                    <CheckBox x:Name="AxisBindLockEnabledCheckBox" Content="Lock selected axis at center when bind is active"
                                              Margin="0,0,0,8" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock x:Name="AxisBindLockStatusTextBlock" Grid.Row="0"
                                                   Foreground="#C8C8C8" Text="Bind: not set" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <WrapPanel Grid.Row="1" Orientation="Horizontal">
                                            <Button x:Name="AxisBindLockBindButton" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"
                                                    Content="Bind button…" Click="AxisBindLockBindButton_OnClick"/>
                                            <Button x:Name="AxisBindLockClearButton" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"
                                                    Content="Сброс бинда" Click="AxisBindLockClearButton_OnClick"/>
                                        </WrapPanel>
                                    </Grid>
                                    <TextBlock x:Name="AxisBindLockHintTextBlock" Foreground="#A0A0A0" TextWrapping="Wrap"
                                               Text="Blocks filtered output on the stream axis (vJoy). Bind: press any controller button within 5 s. Each press toggles lock on/off."/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="6,0,0,8">
                                <StackPanel>
                                    <TextBlock x:Name="CalibrationHeaderTextBlock" FontSize="23" FontWeight="SemiBold" Margin="0,0,0,10" Text="Calibration"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="CalibrationMinLabelTextBlock" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Min"/>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                            <Slider x:Name="CalibrationMinSlider" Width="260" Minimum="-1.0" Maximum="0.0" Value="-1.0"
                                                    ValueChanged="CalibrationSlider_OnValueChanged"/>
                                            <TextBlock x:Name="CalibrationMinTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock x:Name="CalibrationCenterLabelTextBlock" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Center"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                            <Slider x:Name="CalibrationCenterSlider" Width="260" Minimum="-0.5" Maximum="0.5" Value="0.0"
                                                    ValueChanged="CalibrationSlider_OnValueChanged"/>
                                            <TextBlock x:Name="CalibrationCenterTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock x:Name="CalibrationMaxLabelTextBlock" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Max"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                            <Slider x:Name="CalibrationMaxSlider" Width="260" Minimum="0.0" Maximum="1.0" Value="1.0"
                                                    ValueChanged="CalibrationSlider_OnValueChanged"/>
                                            <TextBlock x:Name="CalibrationMaxTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="FiltersTab" Header="Filters">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,6,8">
                                <StackPanel>
                                    <TextBlock x:Name="DeadzoneHeaderTextBlock" FontSize="23" FontWeight="SemiBold" Margin="0,0,0,10" Text="Deadzone"/>
                                    <CheckBox x:Name="DeadzoneEnabledCheckBox" Content="Enabled" IsChecked="True" Margin="0,0,0,8"
                                              Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <CheckBox x:Name="DeadzoneDynamicCheckBox" Content="Dynamic deadzone" IsChecked="False" Margin="0,0,0,8"
                                              Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <TextBlock x:Name="DeadzoneHintTextBlock" Foreground="#A0A0A0" TextWrapping="Wrap" Margin="0,0,0,8"
                                               Text="Tip: deadzone removes tiny center jitter when you barely touch the stick."/>
                                    <TextBlock x:Name="DeadzoneRadiusLabelTextBlock" Text="Radius" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Slider x:Name="DeadzoneRadiusSlider" Width="240" Minimum="0" Maximum="0.2" Value="0.03"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="DeadzoneRadiusTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock x:Name="MedianHeaderTextBlock" FontSize="23" FontWeight="SemiBold" Margin="0,16,0,10" Text="Median / Hampel"/>
                                    <CheckBox x:Name="MedianEnabledCheckBox" Content="Median filter enabled" IsChecked="True"
                                              Margin="0,0,0,8" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <TextBlock x:Name="MedianWindowLabelTextBlock" Text="Median window" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="MedianWindowSlider" Width="240" Minimum="3" Maximum="25" TickFrequency="2"
                                                IsSnapToTickEnabled="True" Value="5" ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="MedianWindowTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <CheckBox x:Name="HampelEnabledCheckBox" Content="Hampel outlier filter enabled" IsChecked="True"
                                              Margin="0,0,0,8" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <TextBlock x:Name="MedianHampelHintTextBlock" Foreground="#A0A0A0" TextWrapping="Wrap" Margin="0,0,0,8"
                                               Text="Tip: median/hampel suppress random spikes without changing normal stick travel too much."/>
                                    <TextBlock x:Name="HampelWindowLabelTextBlock" Text="Hampel window" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="HampelWindowSlider" Width="240" Minimum="5" Maximum="31" TickFrequency="2"
                                                IsSnapToTickEnabled="True" Value="9" ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="HampelWindowTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock x:Name="HampelSigmaLabelTextBlock" Text="Sigma multiplier" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Slider x:Name="HampelSigmaSlider" Width="240" Minimum="1.0" Maximum="6.0" Value="3.0"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="HampelSigmaTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="6,0,0,8">
                                <StackPanel>
                                    <TextBlock x:Name="SpikeHeaderTextBlock" FontSize="23" FontWeight="SemiBold" Margin="0,0,0,10" Text="Anti-spike and smoothing"/>

                                    <CheckBox x:Name="SpikeGateEnabledCheckBox" Content="Anti-spike gate enabled" IsChecked="True"
                                              Margin="0,0,0,8" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <CheckBox x:Name="RadialSpikeZonesCheckBox" Content="Radial zones (center / outer)" IsChecked="True"
                                              Margin="0,0,0,8" Checked="RadialSpikeZonesCheckBox_OnChanged" Unchecked="RadialSpikeZonesCheckBox_OnChanged"/>
                                    <TextBlock x:Name="RadialSpikeHintTextBlock" Foreground="#A0A0A0" TextWrapping="Wrap" Margin="0,0,0,8"
                                               Text="Near center: sharp micro-spikes are cut; at full deflection: only very sharp jumps."/>

                                    <TextBlock x:Name="CenterZoneLabelTextBlock" Text="Center zone boundary |raw|" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="CenterZoneSlider" Width="240" Minimum="0.12" Maximum="0.50" Value="0.28"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="CenterZoneTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="0.28"/>
                                    </StackPanel>

                                    <TextBlock x:Name="CenterSpikeSensitivityLabelTextBlock" Text="Center spike sensitivity (delta)" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="CenterSpikeSensitivitySlider" Style="{StaticResource FineCenterDeltaSliderStyle}"
                                                Width="240" Minimum="0.03" Maximum="0.15" Value="0.05"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="CenterSpikeSensitivityTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="0.050"/>
                                    </StackPanel>

                                    <TextBlock x:Name="CenterSmoothingMultiplierLabelTextBlock" Text="Center smoothing multiplier" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Slider x:Name="CenterSmoothingMultiplierSlider" Width="240" Minimum="0.5" Maximum="3.0"
                                                TickFrequency="0.1" IsSnapToTickEnabled="True" Value="1.0"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="CenterSmoothingMultiplierTextBlock" Width="70" Margin="10,0,0,0"
                                                   VerticalAlignment="Center" Text="1.0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="CenterSmoothingMultiplierHintTextBlock" Foreground="#A0A0A0" TextWrapping="Wrap" Margin="0,0,0,8"
                                               Text="1.0 = default; higher = stronger suppression of sharp micro-moves near center."/>

                                    <TextBlock x:Name="SpikeDeltaLabelTextBlock" Text="Outer spike delta threshold" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="SpikeDeltaSlider" Style="{StaticResource FineDeltaSliderStyle}"
                                                Width="240" Minimum="0.05" Maximum="1.0" Value="0.38"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="SpikeDeltaTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock x:Name="SpikeVelocityLabelTextBlock" Text="Outer spike velocity / sec" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="SpikeVelocitySlider" Width="240" Minimum="1.0" Maximum="20.0" Value="11.0"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="SpikeVelocityTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock x:Name="SpikeHoldLabelTextBlock" Text="Max suppressed in a row" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="SpikeHoldSlider" Width="240" Minimum="1" Maximum="6" TickFrequency="1"
                                                IsSnapToTickEnabled="True" Value="1" ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="SpikeHoldTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="SpikeHintTextBlock" Foreground="#A0A0A0" TextWrapping="Wrap" Margin="0,0,0,8"
                                               Text="Tip: 1 suppresses only a single spike, then allows sustained movement."/>

                                    <TextBlock x:Name="ZImpulseGuardHeaderTextBlock" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,8"
                                               Text="Z impulse protection"/>
                                    <CheckBox x:Name="ZImpulseGuardEnabledCheckBox" Content="Protect from false Z impulses near center" IsChecked="True"
                                              Margin="0,0,0,8" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <TextBlock x:Name="ZImpulseGuardHintTextBlock" Foreground="#A0A0A0" TextWrapping="Wrap" Margin="0,0,0,8"
                                               Text="Blocks brief one/two-sample Z jerks near center; sustained movement passes after confirmation."/>
                                    <TextBlock x:Name="ZImpulseCenterRadiusLabelTextBlock" Text="Guard center radius |raw|" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="ZImpulseCenterRadiusSlider" Width="240" Minimum="0.10" Maximum="0.60" Value="0.35"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="ZImpulseCenterRadiusTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="0.35"/>
                                    </StackPanel>
                                    <TextBlock x:Name="ZImpulseThresholdLabelTextBlock" Text="Intent threshold (delta)" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="ZImpulseThresholdSlider" Width="240" Minimum="0.02" Maximum="0.20" Value="0.06"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="ZImpulseThresholdTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="0.060"/>
                                    </StackPanel>
                                    <TextBlock x:Name="ZImpulseConfirmLabelTextBlock" Text="Confirm samples" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="ZImpulseConfirmSlider" Width="240" Minimum="1" Maximum="5" TickFrequency="1"
                                                IsSnapToTickEnabled="True" Value="2" ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="ZImpulseConfirmTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="2"/>
                                    </StackPanel>

                                    <TextBlock x:Name="AxisIntentHeaderTextBlock" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,8"
                                               Text="Axis intent (target)"/>
                                    <CheckBox x:Name="AxisIntentEnabledCheckBox" Content="Detect intentional movement on selected axis"
                                              IsChecked="True" Margin="0,0,0,8" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <TextBlock x:Name="AxisIntentHintTextBlock" Foreground="#A0A0A0" TextWrapping="Wrap" Margin="0,0,0,8"
                                               Text="Intentional movement disables cross-axis lock and Z impulse guard. Brief impulses stay parasitic."/>
                                    <TextBlock x:Name="AxisIntentDeflectionLabelTextBlock" Text="Intent deflection threshold |value|" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="AxisIntentDeflectionSlider" Width="240" Minimum="0.03" Maximum="0.30" Value="0.07"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="AxisIntentDeflectionTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="0.07"/>
                                    </StackPanel>
                                    <TextBlock x:Name="AxisIntentStrongLabelTextBlock" Text="Strong deflection (instant intent)" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="AxisIntentStrongSlider" Width="240" Minimum="0.10" Maximum="0.60" Value="0.35"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="AxisIntentStrongTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="0.35"/>
                                    </StackPanel>
                                    <TextBlock x:Name="AxisIntentConfirmLabelTextBlock" Text="Confirm samples" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="AxisIntentConfirmSlider" Width="240" Minimum="1" Maximum="5" TickFrequency="1"
                                                IsSnapToTickEnabled="True" Value="2" ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="AxisIntentConfirmTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="2"/>
                                    </StackPanel>

                                    <TextBlock x:Name="CrossAxisShieldHeaderTextBlock" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,8"
                                               Text="Cross-axis shield"/>
                                    <CheckBox x:Name="CrossAxisShieldEnabledCheckBox" Content="Strengthen selected axis when other axes are active"
                                              IsChecked="True" Margin="0,0,0,8" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <TextBlock x:Name="CrossAxisShieldHintTextBlock" Foreground="#A0A0A0" TextWrapping="Wrap" Margin="0,0,0,8"
                                               Text="When watched axes move fast, selected axis gets stricter rate limit + stronger EMA smoothing."/>
                                    <TextBlock x:Name="CrossAxisTargetLabelTextBlock" Text="Target axis for shield" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="CrossAxisTargetComboBox" Width="240" Height="28" Margin="0,0,0,8"
                                              SelectedValue="SELECTED" SelectedValuePath="Tag"
                                              SelectionChanged="FilterSettingChanged">
                                        <ComboBoxItem Tag="SELECTED" Content="Selected input axis"/>
                                        <ComboBoxItem Tag="X" Content="X"/>
                                        <ComboBoxItem Tag="Y" Content="Y"/>
                                        <ComboBoxItem Tag="Z" Content="Z"/>
                                        <ComboBoxItem Tag="RX" Content="Rotation X"/>
                                        <ComboBoxItem Tag="RY" Content="Rotation Y"/>
                                        <ComboBoxItem Tag="RZ" Content="Rotation Z"/>
                                        <ComboBoxItem Tag="SL0" Content="Slider 0"/>
                                        <ComboBoxItem Tag="SL1" Content="Slider 1"/>
                                    </ComboBox>
                                    <TextBlock x:Name="CrossAxisWatchLabelTextBlock" Text="Watched axes (activity source)" Margin="0,0,0,4"/>
                                    <WrapPanel Margin="0,0,0,8">
                                        <CheckBox x:Name="CrossWatchXCheckBox" Content="X" Margin="0,0,10,4" IsChecked="True" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                        <CheckBox x:Name="CrossWatchYCheckBox" Content="Y" Margin="0,0,10,4" IsChecked="True" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                        <CheckBox x:Name="CrossWatchZCheckBox" Content="Z" Margin="0,0,10,4" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                        <CheckBox x:Name="CrossWatchRXCheckBox" Content="RX" Margin="0,0,10,4" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                        <CheckBox x:Name="CrossWatchRYCheckBox" Content="RY" Margin="0,0,10,4" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                        <CheckBox x:Name="CrossWatchRZCheckBox" Content="RZ" Margin="0,0,10,4" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    </WrapPanel>
                                    <TextBlock x:Name="CrossAxisDeflectionLabelTextBlock" Text="Other axis deflection threshold |value|" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="CrossAxisDeflectionSlider" Width="240" Minimum="0.02" Maximum="0.50" Value="0.10"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="CrossAxisDeflectionTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="0.10"/>
                                    </StackPanel>
                                    <CheckBox x:Name="CrossAxisDominanceCheckBox" Content="Require watched axes stronger than target"
                                              IsChecked="False" Margin="0,0,0,4" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <TextBlock x:Name="CrossAxisDominanceLabelTextBlock" Text="Other-axis dominance ratio" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="CrossAxisDominanceSlider" Width="240" Minimum="0.80" Maximum="2.50" Value="1.15"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="CrossAxisDominanceTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="1.15"/>
                                    </StackPanel>
                                    <CheckBox x:Name="CrossAxisRespectIntentCheckBox" Content="Disable shield while target movement is intentional"
                                              IsChecked="True" Margin="0,0,0,8" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <TextBlock x:Name="CrossAxisVelocityMinLabelTextBlock" Text="Other axis velocity min / sec" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="CrossAxisVelocityMinSlider" Width="240" Minimum="0.2" Maximum="20.0" Value="0.25"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="CrossAxisVelocityMinTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="0.25"/>
                                    </StackPanel>
                                    <TextBlock x:Name="CrossAxisVelocityMaxLabelTextBlock" Text="Other axis velocity max / sec" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="CrossAxisVelocityMaxSlider" Width="240" Minimum="2.0" Maximum="60.0" Value="30.0"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="CrossAxisVelocityMaxTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="30.00"/>
                                    </StackPanel>
                                    <TextBlock x:Name="CrossAxisRateMulLabelTextBlock" Text="Rate limiter multiplier when active" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="CrossAxisRateMulSlider" Width="240" Minimum="0.1" Maximum="1.0" Value="0.35"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="CrossAxisRateMulTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="0.35"/>
                                    </StackPanel>
                                    <TextBlock x:Name="CrossAxisEmaMulLabelTextBlock" Text="EMA alpha multiplier when active" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="CrossAxisEmaMulSlider" Width="240" Minimum="0.1" Maximum="1.0" Value="0.40"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="CrossAxisEmaMulTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="0.40"/>
                                    </StackPanel>
                                    <CheckBox x:Name="CrossAxisHardLockCheckBox" Content="Hard lock target axis while other axes are active"
                                              IsChecked="True" Margin="0,0,0,8" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <CheckBox x:Name="CrossAxisHardLockCenterCheckBox" Content="Hard lock anchor only at center (0.0)"
                                              IsChecked="True" Margin="0,0,0,8" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <TextBlock x:Name="CrossAxisLeakLabelTextBlock" Text="Lock leak multiplier (tiny manual activation)" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="CrossAxisLeakSlider" Width="240" Minimum="0.0" Maximum="0.35" Value="0.0"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="CrossAxisLeakTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center" Text="0.00"/>
                                    </StackPanel>

                                    <CheckBox x:Name="RateLimiterEnabledCheckBox" Content="Rate limiter enabled" IsChecked="True"
                                              Margin="0,0,0,8" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <TextBlock x:Name="RateLimiterHintTextBlock" Foreground="#A0A0A0" TextWrapping="Wrap" Margin="0,0,0,8"
                                               Text="Tip: rate limiter caps too-fast jumps and keeps output smoother for game input."/>
                                    <TextBlock x:Name="RateLimiterLabelTextBlock" Text="Max delta / sec" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Slider x:Name="RateLimiterSlider" Width="240" Minimum="0.5" Maximum="10.0" Value="8.0"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="RateLimiterTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <CheckBox x:Name="EmaEnabledCheckBox" Content="EMA smoothing enabled" IsChecked="True"
                                              Margin="0,0,0,8" Checked="FilterSettingChanged" Unchecked="FilterSettingChanged"/>
                                    <TextBlock x:Name="EmaHintTextBlock" Foreground="#A0A0A0" TextWrapping="Wrap" Margin="0,0,0,8"
                                               Text="Tip: EMA gives smooth movement, lower alpha means softer but slower response."/>
                                    <TextBlock x:Name="EmaAlphaLabelTextBlock" Text="EMA alpha" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Slider x:Name="EmaAlphaSlider" Width="240" Minimum="0.01" Maximum="1.0" Value="0.40"
                                                ValueChanged="FilterSliderChanged"/>
                                        <TextBlock x:Name="EmaAlphaTextBlock" Width="70" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="MonitorTab" Header="Monitor" Loaded="MonitorTab_OnLoaded">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <UniformGrid Grid.Row="0" Columns="6" Margin="0,0,0,8">
                            <Border Margin="4" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="6" Padding="8" Background="#2A2A2A">
                                <StackPanel>
                                    <TextBlock x:Name="RawMetricLabelTextBlock" Text="Raw"/>
                                    <TextBlock x:Name="RawValueTextBlock" FontSize="20" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="6" Padding="8" Background="#2A2A2A">
                                <StackPanel>
                                    <TextBlock x:Name="FilteredMetricLabelTextBlock" Text="Filtered"/>
                                    <TextBlock x:Name="FilteredValueTextBlock" FontSize="20" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="6" Padding="8" Background="#2A2A2A">
                                <StackPanel>
                                    <TextBlock x:Name="DeltaMetricLabelTextBlock" Text="Delta"/>
                                    <TextBlock x:Name="DeltaValueTextBlock" FontSize="20" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="6" Padding="8" Background="#2A2A2A">
                                <StackPanel>
                                    <TextBlock x:Name="SpikeMetricLabelTextBlock" Text="Suppressed spikes"/>
                                    <TextBlock x:Name="SpikeCountTextBlock" FontSize="20" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="6" Padding="8" Background="#2A2A2A">
                                <StackPanel>
                                    <TextBlock x:Name="HampelMetricLabelTextBlock" Text="Hampel outliers"/>
                                    <TextBlock x:Name="HampelCountTextBlock" FontSize="20" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="6" Padding="8" Background="#2A2A2A">
                                <StackPanel>
                                    <TextBlock x:Name="SequenceMetricLabelTextBlock" Text="Sample #"/>
                                    <TextBlock x:Name="SequenceTextBlock" FontSize="20" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="1" Margin="0,0,0,8" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="6"
                                Padding="10,8" Background="#2A2A2A">
                            <StackPanel>
                                <TextBlock x:Name="MonitorAxesHeaderTextBlock" Foreground="#A0A0A0" FontSize="12"
                                           Text="Other axes on chart (device raw)"/>
                                <WrapPanel x:Name="MonitorAxisTogglesPanel" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="8" Padding="10" Background="#111111">
                            <Grid>
                                <Canvas x:Name="ChartCanvas" Background="#101010"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                        SizeChanged="ChartCanvas_OnSizeChanged">
                                    <Polyline x:Name="AxisXPolyline" Panel.ZIndex="8" Stroke="#3B82F6" StrokeThickness="1.5" SnapsToDevicePixels="True"/>
                                    <Polyline x:Name="AxisYPolyline" Panel.ZIndex="8" Stroke="#F59E0B" StrokeThickness="1.5" SnapsToDevicePixels="True"/>
                                    <Polyline x:Name="AxisZPolyline" Panel.ZIndex="8" Stroke="#A855F7" StrokeThickness="1.5" SnapsToDevicePixels="True"/>
                                    <Polyline x:Name="AxisRxPolyline" Panel.ZIndex="8" Stroke="#06B6D4" StrokeThickness="1.5" SnapsToDevicePixels="True"/>
                                    <Polyline x:Name="AxisRyPolyline" Panel.ZIndex="8" Stroke="#EC4899" StrokeThickness="1.5" SnapsToDevicePixels="True"/>
                                    <Polyline x:Name="AxisRzPolyline" Panel.ZIndex="8" Stroke="#EAB308" StrokeThickness="1.5" SnapsToDevicePixels="True"/>
                                    <Polyline x:Name="AxisSl0Polyline" Panel.ZIndex="8" Stroke="#84CC16" StrokeThickness="1.5" SnapsToDevicePixels="True"/>
                                    <Polyline x:Name="AxisSl1Polyline" Panel.ZIndex="8" Stroke="#F97316" StrokeThickness="1.5" SnapsToDevicePixels="True"/>
                                    <Polyline x:Name="RawPolyline" Panel.ZIndex="5" Stroke="#EF4444" StrokeThickness="1.5" SnapsToDevicePixels="True"/>
                                    <Polyline x:Name="FilteredPolyline" Panel.ZIndex="6" Stroke="#22C55E" StrokeThickness="2" SnapsToDevicePixels="True"/>
                                </Canvas>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" Padding="8,6"
                                        Background="#CC000000" CornerRadius="4" MaxWidth="280">
                                    <StackPanel x:Name="ChartLegendPanel"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem x:Name="SettingsTab" Header="Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="8">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock x:Name="SettingsHeaderTextBlock" FontSize="23" FontWeight="SemiBold" Margin="0,0,0,10" Text="Application settings"/>
                                    <TextBlock x:Name="LanguageLabelTextBlock" Margin="0,0,0,4" Text="Language"/>
                                    <ComboBox x:Name="LanguageComboBox" Height="30" Margin="0,0,0,10" SelectionChanged="LanguageComboBox_OnSelectionChanged">
                                        <ComboBoxItem Content="RU" IsSelected="True"/>
                                        <ComboBoxItem Content="EN"/>
                                    </ComboBox>
                                    <CheckBox x:Name="EnableLoggingCheckBox" Content="Enable diagnostics log" Margin="0,0,0,8"
                                              Checked="SettingsCheckBoxChanged" Unchecked="SettingsCheckBoxChanged"/>
                                    <CheckBox x:Name="ResetLogOnStartupCheckBox" Content="Clear log file on app start" Margin="0,0,0,8"
                                              Checked="SettingsCheckBoxChanged" Unchecked="SettingsCheckBoxChanged"/>
                                    <Button x:Name="ClearLogButton" Style="{StaticResource SecondaryButtonStyle}" Width="220" Margin="0,0,0,12"
                                            Content="Clear log now" Click="ClearLogButton_OnClick"/>
                                    <CheckBox x:Name="ShowHintsCheckBox" Content="Show filter hints" Margin="0,0,0,8"
                                              Checked="SettingsCheckBoxChanged" Unchecked="SettingsCheckBoxChanged"/>
                                    <CheckBox x:Name="AutoApplyInAppCheckBox" Content="Auto-apply last applied settings when app opens" Margin="0,0,0,12"
                                              Checked="SettingsCheckBoxChanged" Unchecked="SettingsCheckBoxChanged"/>
                                    <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start agent with Windows" Margin="0,0,0,12"
                                              Checked="SettingsCheckBoxChanged" Unchecked="SettingsCheckBoxChanged"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="ResetAppliedButton" Style="{StaticResource SecondaryButtonStyle}" Width="220"
                                                Content="Reset applied settings" Click="ResetAppliedButton_OnClick"/>
                                        <Button x:Name="DefaultSettingsButton" Style="{StaticResource SecondaryButtonStyle}" Width="220" Margin="10,0,0,0"
                                                Content="Default settings" Click="DefaultSettingsButton_OnClick"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <StatusBar Grid.Row="2" Background="#202020" Foreground="#F3F3F3" BorderBrush="#3D3D3D" BorderThickness="1">
                <StatusBarItem>
                    <TextBlock x:Name="StatusTextBlock" Text="Ready"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Grid>
</Window>
